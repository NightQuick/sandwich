{
  "compilerOptions": {
    "types": ["vite/client"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "@script/*": ["./public/script/*"],
      "@styles/*": ["./public/styles/*"],
      "@images/*": ["./public/i/*"],
      "@/*": ["./public/*"],
      "@constants": ["./public/constants.ts"],
      "@callbacks": ["./public/callbacks.ts"],
      "@api": ["./public/api.ts"],
      "@dp/*": ["./public/script/dataProcessing/*"],
      "@elements/*": ["./public/script/elements/*"],
      "@ui/*": ["./public/script/UI/*"]
    }
  },
  "include": ["src/**/*", "public/**/*", "env.d.ts"]
}
